# ─── DATABASE ────────────────────────────────────────────────────────────────
# Neon dashboard → your project → Connection string → "Pooled connection"
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ─── AUTH.JS ─────────────────────────────────────────────────────────────────
# Secret key used to sign sessions — generate with: openssl rand -hex 32
# Use the same value in production (Vercel)
AUTH_SECRET=

# Base URL of the app
# Development: http://localhost:3000
# Production (Vercel): https://your-app.vercel.app
AUTH_URL=

# ─── GITHUB OAUTH ────────────────────────────────────────────────────────────
# GitHub → Settings → Developer settings → OAuth Apps → your app
# Set callback URL to: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── UPSTASH REDIS ───────────────────────────────────────────────────────────
# Upstash dashboard → your Redis database → REST API tab
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── ADMIN ───────────────────────────────────────────────────────────────────
# Protects POST /api/activities (database seed/reset endpoint)
# Generate with: openssl rand -hex 32
ADMIN_SEED_KEY=

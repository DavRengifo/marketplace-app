generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sessions      Session[]
  favorites     Favorite[]
  bookings      Booking[]
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  activityId Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
}

model Booking {
  id         Int      @id @default(autoincrement())
  userId     Int
  activityId Int
  createdAt  DateTime @default(now())
  status     String   @default("pending")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model Activity {
  id            Int     @id @default(autoincrement())
  title         String
  description   String
  price         Decimal
  location      String
  category      String
  imageUrl      String?
  duration      String?
  meetingPoint  String?
  language      String?
  included      String?
  cancellation  String?
  bestFor       String?
  bookingCount  Int      @default(0)
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
  favorites Favorite[]
  bookings  Booking[]
}
